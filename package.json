{
  "name": "blackjack",
  "version": "1.0.0",
  "private": true,
  "workspaces": [
    "packages/shared",
    "packages/backend",
    "packages/frontend"
  ],
  "scripts": {
    "dev": "npm run pack:cards && concurrently \"npm run dev:backend\" \"npm run dev:frontend\"",
    "dev:backend": "npm run dev --workspace=packages/backend",
    "dev:frontend": "npm run dev --workspace=packages/frontend",
    "test": "npm run test --workspaces --if-present",
    "test:backend": "npm run test --workspace=packages/backend",
    "pack:cards": "node scripts/pack-cards.mjs"
  },
  "devDependencies": {
    "concurrently": "^9.1.2",
    "sharp": "^0.34.5"
  },
  "dependencies": {
    "@esbuild/darwin-arm64": "^0.27.4"
  }
}
